<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Учи таблицу умножения!"
            android:textSize="60dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Это я, Сэнко мофу-мофу! Я надеюсь ты выучишь таблицу умножения, Саша. И не будешь роблокс нубиком!"
            android:textSize="30dp"
            android:translationY="50dp"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="test1_round"
            android:text="Начать тест (умножение на 2, 3 и 4)"
            android:translationY="55dp"></Button>

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/first_fox"
            android:translationY="80dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>